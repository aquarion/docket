{
	"$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!vendor", "!node_modules", "!htdocs/static/snowstorm"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "off",
				"noArguments": "off"
			},
			"correctness": {
				"noInnerDeclarations": "off"
			},
			"style": {
				"noParameterAssign": "off",
				"useTemplate": "off",
				"useConst": "off"
			},
			"suspicious": {
				"noVar": "off",
				"noSelfCompare": "off",
				"noRedeclare": "off"
			}
		}
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": false
		},
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		},
		"globals": [
			"window",
			"document",
			"console",
			"URLSearchParams",
			"fetch",
			"Promise",
			"SunCalc",
			"twemoji",
			"ICAL",
			"Toastify"
		]
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
